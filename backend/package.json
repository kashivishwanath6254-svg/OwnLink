{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "clean": "rm -rf ./dist ./tsconfig.tsbuildinfo",
    "build": "pnpm clean && tsc",
    "start": "node ./dist/index.js",
    "dev": "tsx watch ./src/index.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "db:status": "dbmate status",
    "db:up": "dbmate up",
    "db:down": "dbmate down",
    "db:new": "dbmate new",
    "db:dump": "dbmate dump"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
