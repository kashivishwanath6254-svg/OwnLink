  "dependencies": {
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.3.0",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/node": "25.9.3",
    "dbmate": "2.33.0",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  }
